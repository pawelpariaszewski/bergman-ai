{
  "$extensions": {
    "com.bergman": {
      "name": "bergman",
      "version": "0.0.1"
    }
  },
  "primitives": {
    "color": {
      "$type": "color",
      "grey": {
        "0": {
          "$value": {
            "colorSpace": "srgb",
            "components": [1, 1, 1],
            "alpha": 1,
            "hex": "#FFFFFF"
          }
        },
        "100": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.94902, 0.94902, 0.94902],
            "alpha": 1,
            "hex": "#F2F2F2"
          }
        },
        "200": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.882353, 0.882353, 0.882353],
            "alpha": 1,
            "hex": "#E1E1E1"
          }
        },
        "300": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.8, 0.8, 0.8],
            "alpha": 1,
            "hex": "#CCCCCC"
          }
        },
        "400": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.678431, 0.678431, 0.678431],
            "alpha": 1,
            "hex": "#ADADAD"
          }
        },
        "500": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.6, 0.6, 0.6],
            "alpha": 1,
            "hex": "#999999"
          }
        },
        "600": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.568627, 0.568627, 0.568627],
            "alpha": 1,
            "hex": "#919191"
          }
        },
        "700": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.458824, 0.458824, 0.458824],
            "alpha": 1,
            "hex": "#757575"
          }
        },
        "800": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.2, 0.2, 0.2],
            "alpha": 1,
            "hex": "#333333"
          }
        },
        "900": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0, 0, 0],
            "alpha": 1,
            "hex": "#000000"
          }
        }
      }
    },
    "scale": {
      "$type": "dimension",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "1": { "$value": { "value": 1, "unit": "px" } },
      "2": { "$value": { "value": 2, "unit": "px" } },
      "4": { "$value": { "value": 4, "unit": "px" } },
      "6": { "$value": { "value": 6, "unit": "px" } },
      "8": { "$value": { "value": 8, "unit": "px" } },
      "10": { "$value": { "value": 10, "unit": "px" } },
      "12": { "$value": { "value": 12, "unit": "px" } },
      "16": { "$value": { "value": 16, "unit": "px" } },
      "20": { "$value": { "value": 20, "unit": "px" } },
      "24": { "$value": { "value": 24, "unit": "px" } },
      "32": { "$value": { "value": 32, "unit": "px" } },
      "48": { "$value": { "value": 48, "unit": "px" } },
      "56": { "$value": { "value": 56, "unit": "px" } },
      "64": { "$value": { "value": 64, "unit": "px" } },
      "80": { "$value": { "value": 80, "unit": "px" } },
      "96": { "$value": { "value": 96, "unit": "px" } },
      "112": { "$value": { "value": 112, "unit": "px" } },
      "120": { "$value": { "value": 120, "unit": "px" } },
      "144": { "$value": { "value": 144, "unit": "px" } },
      "160": { "$value": { "value": 160, "unit": "px" } },
      "168": { "$value": { "value": 168, "unit": "px" } },
      "240": { "$value": { "value": 240, "unit": "px" } },
      "320": { "$value": { "value": 320, "unit": "px" } },
      "360": { "$value": { "value": 360, "unit": "px" } },
      "480": { "$value": { "value": 480, "unit": "px" } },
      "640": { "$value": { "value": 640, "unit": "px" } },
      "720": { "$value": { "value": 720, "unit": "px" } },
      "960": { "$value": { "value": 960, "unit": "px" } },
      "1000": { "$value": { "value": 1000, "unit": "px" } },
      "full": {
        "$type": "number",
        "$value": 100,
        "$description": "Relative full size expressed as a percentage (100%).",
        "$extensions": {
          "com.bergman": {
            "css": "100%"
          }
        }
      }
    },
    "font": {
      "family": {
        "$type": "fontFamily",
        "inter": {
          "$value": "Inter",
          "$extensions": {
            "com.bergman": {
              "fontFace": {
                "style": "normal",
                "weight": "100 900",
                "display": "swap",
                "src": "https://cdn.ingrid.com/static/assets/Inter.var.woff2"
              }
            }
          }
        },
        "default": {
          "$value": [
            "{primitives.font.family.inter}",
            "-apple-system",
            "BlinkMacSystemFont",
            "Segoe UI",
            "Roboto",
            "sans-serif"
          ]
        }
      },
      "size": {
        "$type": "dimension",
        "12": { "$value": { "value": 12, "unit": "px" } },
        "13": { "$value": { "value": 13, "unit": "px" } },
        "14": { "$value": { "value": 14, "unit": "px" } },
        "16": { "$value": { "value": 16, "unit": "px" } }
      },
      "weight": {
        "$type": "fontWeight",
        "400": { "$value": 400 },
        "500": { "$value": 500 }
      },
      "letterSpacing": {
        "$type": "dimension",
        "12": { "$value": { "value": 0, "unit": "px" } },
        "13": { "$value": { "value": -0.039, "unit": "px" } },
        "14": { "$value": { "value": -0.084, "unit": "px" } },
        "16": { "$value": { "value": -0.176, "unit": "px" } }
      },
      "lineHeight": {
        "$type": "dimension",
        "16": { "$value": { "value": 16, "unit": "px" } },
        "20": { "$value": { "value": 20, "unit": "px" } }
      }
    }
  },
  "functional": {
    "radius": {
      "$type": "dimension",
      "25": { "$value": "{primitives.scale.2}" },
      "50": { "$value": "{primitives.scale.4}" },
      "75": { "$value": "{primitives.scale.6}" },
      "100": { "$value": "{primitives.scale.8}" },
      "125": { "$value": "{primitives.scale.10}" },
      "200": { "$value": "{primitives.scale.16}" },
      "300": { "$value": "{primitives.scale.24}" },
      "none": { "$value": "{primitives.scale.0}" },
      "full": { "$value": "{primitives.scale.1000}" }
    },
    "space": {
      "$type": "dimension",
      "0": { "$value": "{primitives.scale.0}" },
      "12": { "$value": "{primitives.scale.1}" },
      "25": { "$value": "{primitives.scale.2}" },
      "50": { "$value": "{primitives.scale.4}" },
      "75": { "$value": "{primitives.scale.6}" },
      "100": { "$value": "{primitives.scale.8}" },
      "150": { "$value": "{primitives.scale.12}" },
      "200": { "$value": "{primitives.scale.16}" },
      "250": { "$value": "{primitives.scale.20}" },
      "300": { "$value": "{primitives.scale.24}" }
    },
    "size": {
      "$type": "dimension",
      "0": { "$value": "{primitives.scale.0}" },
      "12": { "$value": "{primitives.scale.1}" },
      "25": { "$value": "{primitives.scale.2}" },
      "50": { "$value": "{primitives.scale.4}" },
      "75": { "$value": "{primitives.scale.6}" },
      "100": { "$value": "{primitives.scale.8}" },
      "150": { "$value": "{primitives.scale.12}" },
      "200": { "$value": "{primitives.scale.16}" },
      "300": { "$value": "{primitives.scale.24}" },
      "350": { "$value": "{primitives.scale.20}" },
      "400": { "$value": "{primitives.scale.32}" },
      "600": { "$value": "{primitives.scale.48}" },
      "700": { "$value": "{primitives.scale.56}" },
      "800": { "$value": "{primitives.scale.64}" },
      "1000": { "$value": "{primitives.scale.80}" },
      "1200": { "$value": "{primitives.scale.96}" },
      "1400": { "$value": "{primitives.scale.112}" },
      "1500": { "$value": "{primitives.scale.120}" },
      "1800": { "$value": "{primitives.scale.144}" },
      "2000": { "$value": "{primitives.scale.160}" },
      "2100": { "$value": "{primitives.scale.168}" },
      "3000": { "$value": "{primitives.scale.240}" },
      "4000": { "$value": "{primitives.scale.320}" },
      "4500": { "$value": "{primitives.scale.360}" },
      "6000": { "$value": "{primitives.scale.480}" },
      "8000": { "$value": "{primitives.scale.640}" },
      "9000": { "$value": "{primitives.scale.720}" },
      "12000": { "$value": "{primitives.scale.960}" },
      "full": {
        "$type": "number",
        "$value": "{primitives.scale.full}"
      }
    },
    "fontSize": {
      "$type": "dimension",
      "xsm": { "$value": "{primitives.font.size.12}" },
      "sm": { "$value": "{primitives.font.size.13}" },
      "md": { "$value": "{primitives.font.size.14}" },
      "lg": { "$value": "{primitives.font.size.16}" }
    },
    "letterSpacing": {
      "$type": "dimension",
      "xsm": { "$value": "{primitives.font.letterSpacing.12}" },
      "sm": { "$value": "{primitives.font.letterSpacing.13}" },
      "md": { "$value": "{primitives.font.letterSpacing.14}" },
      "lg": { "$value": "{primitives.font.letterSpacing.16}" }
    },
    "lineHeight": {
      "$type": "dimension",
      "sm": { "$value": "{primitives.font.lineHeight.16}" },
      "md": { "$value": "{primitives.font.lineHeight.20}" }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "regular": { "$value": "{primitives.font.weight.400}" }
    },
    "color": {
      "$type": "color",
      "bg": {
        "primary": { "$value": "{primitives.color.grey.0}" },
        "primaryInverse": { "$value": "{primitives.color.grey.900}" }
      }
    }
  }
}
